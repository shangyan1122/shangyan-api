# 服务配置
PORT=3000
NODE_ENV=development

# Supabase 数据库
DATABASE_URL=postgresql://postgres:password@localhost:5432/shangyan
SUPABASE_URL=https://example.supabase.co
SUPABASE_KEY=your-supabase-anon-key
COZE_SUPABASE_URL=https://example.supabase.co
COZE_SUPABASE_KEY=your-supabase-service-key

# JWT
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# 微信支付
WECHAT_MCHID=your-merchant-id
WECHAT_SERIAL_NO=your-serial-no
WECHAT_PRIVATE_KEY=your-private-key
WECHAT_APIV3_KEY=your-apiv3-key

# S3 存储
S3_ENDPOINT=https://s3.amazonaws.com
S3_REGION=ap-northeast-1
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET=shangyan-assets

# Coze API
COZE_API_TOKEN=your-coze-token
COZE_BOT_ID=your-bot-id

# Sentry
SENTRY_DSN=

# AWS
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
