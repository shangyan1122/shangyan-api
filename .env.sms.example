# 腾讯云短信配置
# 文档: https://cloud.tencent.com/document/product/382

# 腾讯云短信 SecretId（从环境变量读取）
TENCENT_CLOUD_SECRET_ID=

# 腾讯云短信 SecretKey（从环境变量读取）
TENCENT_CLOUD_SECRET_KEY=

# 短信应用 App ID
TENCENT_SMS_APP_ID=

# 短信应用 App Key
TENCENT_SMS_APP_KEY=

# 登录验证码短信模板 ID
TENCENT_SMS_LOGIN_TEMPLATE_ID=1234567

# 签名内容（需要在腾讯云申请）
TENCENT_SMS_SIGN=尚宴礼记

# 短信发送区域（默认广州）
TENCENT_SMS_REGION=ap-guangzhou

# ============ 授权管理员手机号 ============
# 只有在此列表中的手机号才能登录管理后台
# 多个号码用逗号分隔
ADMIN_ALLOWED_PHONES=13800138000,13900139000
