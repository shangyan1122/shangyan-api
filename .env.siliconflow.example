# AI服务提供商配置
# 支持: siliconflow, coze, openai
AI_PROVIDER=siliconflow

# ============ 硅基流动 SiliconFlow ============
# 官网: https://cloud.siliconflow.cn
# 注册送2000万tokens，邀请码: 8EGcP8PT
# API密钥: https://cloud.siliconflow.cn/api/keys

SILICONFLOW_API_KEY=your-api-key-here

# 文本模型 (默认使用 Qwen2.5-7B，免费额度内可用)
# 推荐模型:
#   - Qwen/Qwen2.5-7B-Instruct (免费)
#   - Qwen/Qwen2.5-32B-Instruct
#   - Qwen/Qwen2.5-72B-Instruct
#   - deepseek-ai/DeepSeek-V2.5
#   - deepseek-ai/DeepSeek-R1 (带思考能力)
SILICONFLOW_TEXT_MODEL=Qwen/Qwen2.5-7B-Instruct

# 视觉模型 (用于分析照片)
# 推荐模型:
#   - Qwen/Qwen2-VL-7B-Instruct (推荐，免费额度内可用)
#   - Qwen/Qwen2-VL-72B-Instruct
#   - THUDM/glm-4v-9b
SILICONFLOW_VISION_MODEL=Qwen/Qwen2-VL-7B-Instruct

# 生成参数
SILICONFLOW_TEMPERATURE=0.7
SILICONFLOW_MAX_TOKENS=2000

# ============ Coze (火山引擎) - 可选 ============
# 如果 AI_PROVIDER=coze，将使用此配置
# COZE_API_KEY=your-coze-api-key
# COZE_BOT_ID=your-bot-id
# COZE_API_BASE=https://api.coze.cn

# ============ OpenAI 兼容 API - 可选 ============
# 如果 AI_PROVIDER=openai，将使用此配置
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
